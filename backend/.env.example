# Copy to .env and fill in to persist orders to Supabase.
# Without these the app runs with an in-memory store (great for local dev).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the SERVICE_ROLE key (server-side only — bypasses RLS). Never expose it
# in the frontend. RLS in schema.sql denies the public anon key all access.
SUPABASE_KEY=YOUR-SERVICE-ROLE-KEY

# Stripe — get test keys at https://dashboard.stripe.com/test/apikeys
# Without STRIPE_SECRET_KEY the app simulates a successful order (offline demo mode).
STRIPE_SECRET_KEY=sk_test_...
# From `stripe listen` or the dashboard webhook config. Optional but recommended.
STRIPE_WEBHOOK_SECRET=whsec_...
# Where Stripe sends the shopper back after paying / cancelling.
PUBLIC_BASE_URL=http://localhost:5173
# Comma-separated ISO country codes Boobly will ship to (Stripe validates the address).
SHIP_COUNTRIES=CA
# Checkout currency (ISO 4217, lowercase): cad, usd, eur, ...
STRIPE_CURRENCY=cad

# Admin token guarding the admin endpoints + /admin dashboard. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Without it, admin access is denied to everyone (secure by default).
ADMIN_API_TOKEN=

# Email receipts via Resend (https://resend.com). Without a key, emails are
# logged instead of sent (the app still works).
RESEND_API_KEY=
# Use a sender on a domain you've verified in Resend. onboarding@resend.dev
# works for testing without a verified domain.
EMAIL_FROM=Boobly <onboarding@resend.dev>
# Public URL of the logo shown at the top of emails. Defaults to this API's
# /assets/booblyLogo.jpg; override if you host the logo elsewhere.
EMAIL_LOGO_URL=https://boobly-api.onrender.com/assets/booblyLogo.jpg
# Shown in the email footer.
SUPPORT_EMAIL=hello@boobly.com
COMPANY_ADDRESS=Boobly, Montreal, QC, Canada
